HOST=0.0.0.0
PORT=8000
RPM=60

POSTGRES_USER=mavix
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=mavix
DATABASE_URL=postgresql+asyncpg://mavix:changeme_in_production@db:5432/mavix

JWT_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

STUN_SERVER=stun:turn.drone-mavix.ru:3478
TURN_SERVER=turn:turn.drone-mavix.ru:3478
TURNS_SERVER=turns:turn.drone-mavix.ru:443
TURN_USERNAME=myuser
TURN_PASSWORD=changeme

WS_PING_INTERVAL=30
WS_PING_TIMEOUT=45
WS_HANDSHAKE_CAPACITY=5
WS_HANDSHAKE_REFILL_PER_SEC=0.5
WS_AUTH_TIMEOUT=5
WS_AUTH_REFRESH_WARNING_SECONDS=60

CORS_ALLOW_ORIGINS=https://drone-mavix.ru

CLEANUP_ENABLED=true
CLEANUP_INTERVAL_HOURS=24
CLEANUP_DRONE_INACTIVE_DAYS=30

BUILDS_ENABLED=true
BUILDS_TEMPLATE_DIR=/srv/mavix/build-templates
BUILDS_WHEELS_DIR=/srv/mavix/wheels
BUILDS_CACHE_DIR=/var/cache/mavix/builds
BUILDS_PREBUILT_DIR=/srv/mavix/prebuilt
BUILDS_SIGNAL_SERVER_URL=https://drone-mavix.ru

EMAIL_SMTP_HOST=smtp.yandex.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USERNAME=mavix-noreply@yandex.com
EMAIL_SMTP_PASSWORD=changeme
EMAIL_FROM_ADDRESS=mavix-noreply@yandex.com
EMAIL_FROM_NAME=Mavix UAV

WEB_BASE_URL=https://drone-mavix.ru
